<Window xmlns="https://github.com/avaloniaui"
        x:CompileBindings="False"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UABEAvalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Width="1000" Height="700"
        MinWidth="800" MinHeight="500"
        Icon="/Assets/uabeavalonia16.ico"
        x:Class="UABEAvalonia.InfoWindow"
        Title="{Binding Title}"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SystemRegionBrush}">

  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="Margin" Value="2"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Margin" Value="2"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto, *, Auto">
    <Menu Grid.Row="0" Height="32" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,0,1">
      <MenuItem Header="_File">
        <MenuItem Header="Add" Name="menuAdd" />
        <MenuItem Header="Save" HotKey="Ctrl+S" InputGesture="Ctrl+S" Name="menuSave" />
        <MenuItem Header="Save as..." HotKey="Ctrl+Shift+S" InputGesture="Ctrl+Shift+S" Name="menuSaveAs" />
        <MenuItem Header="Create Package File" Name="menuCreatePackageFile" />
        <MenuItem Header="Close" HotKey="Ctrl+W" InputGesture="Ctrl+W" Name="menuClose" />
      </MenuItem>
      <MenuItem Header="_Search">
        <MenuItem Header="Search by name" HotKey="Ctrl+F" InputGesture="Ctrl+F" Name="menuSearchByName" />
        <MenuItem Header="Continue search" HotKey="F3" InputGesture="F3" Name="menuContinueSearch" />
        <MenuItem Header="Go to asset" HotKey="Ctrl+G" InputGesture="Ctrl+G" Name="menuGoToAsset" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Filter" Name="menuFilter" />
        <MenuItem Header="Info" Name="menuInfo" />
        <MenuItem Header="Dependencies" Name="menuDependencies" />
        <MenuItem Header="Hierarchy" Name="menuHierarchy" />
        <MenuItem Header="Scripts" Name="menuScripts" />
        <MenuItem Header="Type tree" Name="menuTypeTree" />
      </MenuItem>
    </Menu>

    <Grid Grid.Row="1" Margin="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" MinWidth="180" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" CornerRadius="4" BorderBrush="{DynamicResource SystemControlDefaultBaseLowBrush}" BorderThickness="1" Margin="0,0,10,0">
        <DataGrid Name="dataGrid" ItemsSource="{Binding Assets}" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All">
          <DataGrid.Resources>
            <local:AssetTypeIconConverter x:Key="IconConverter" />
          </DataGrid.Resources>
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="Name" Width="2*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="local:AssetInfoDataGridItem">
                  <Grid ColumnDefinitions="Auto, *">
                    <Image Grid.Column="0" Source="{Binding TypeClass, Converter={StaticResource IconConverter}}" Width="16" Height="16" Margin="4,0" />
                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Container" Binding="{Binding Container}" Width="2*" />
            <DataGridTextColumn Header="Path ID" Binding="{Binding PathID}" Width="*" />
            <DataGridTextColumn Header="File ID" Binding="{Binding FileID}" Width="*" />
            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
            <DataGridTextColumn Header="Type ID" Binding="{Binding TypeID}" Width="*" />
            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="*" />
            <DataGridTextColumn Header="Modified" Binding="{Binding Modified}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>
      </Border>

      <Border Grid.Column="1" Background="{DynamicResource SystemControlBackgroundChromeLowBrush}" CornerRadius="4" Padding="10">
        <StackPanel Spacing="5">
          <TextBlock Text="Asset Actions" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
          <Button HorizontalAlignment="Stretch" Name="btnViewData" Content="View Data" Classes="accent"/>
          <Button HorizontalAlignment="Stretch" Name="btnEditData" Content="Edit Data" />
          <Button HorizontalAlignment="Stretch" Name="btnSceneView" Content="Scene View" />
          <Separator Margin="0,5"/>
          <Button HorizontalAlignment="Stretch" Name="btnExportRaw" Content="Export Raw" />
          <Button HorizontalAlignment="Stretch" Name="btnExportDump" Content="Export Dump" />
          <Button HorizontalAlignment="Stretch" Name="btnPlugin" Content="Plugins" />
          <Separator Margin="0,5"/>
          <Button HorizontalAlignment="Stretch" Name="btnImportRaw" Content="Import Raw" />
          <Button HorizontalAlignment="Stretch" Name="btnImportDump" Content="Import Dump" />
          <Button HorizontalAlignment="Stretch" Name="btnRemove" Content="Remove" Foreground="#D32F2F" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.Row="2" Margin="10,0,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBox Grid.Column="0" Name="boxSearch" Watermark="Search by name..." />
        <TextBox Grid.Column="1" Name="boxName" IsReadOnly="True" Watermark="Name" />
        <TextBox Grid.Column="2" Name="boxPathId" IsReadOnly="True" Watermark="Path ID" />
        <TextBox Grid.Column="3" Name="boxFileId" IsReadOnly="True" Watermark="File ID" />
        <TextBox Grid.Column="4" Name="boxType" IsReadOnly="True" Watermark="Type" />
    </Grid>
  </Grid>
</Window>

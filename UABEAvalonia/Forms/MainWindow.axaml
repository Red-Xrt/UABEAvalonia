<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UABEAvalonia"
        xmlns:vm="using:UABEAvalonia.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="450"
        Width="550" Height="450"
        MinWidth="450" MinHeight="400"
        Icon="/Assets/uabeavalonia16.ico"
        x:Class="UABEAvalonia.MainWindow"
        Title="UABEA"
        DragDrop.AllowDrop="True"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SystemRegionBrush}">

  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="Margin" Value="2"/>
      <Setter Property="Padding" Value="5,3"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="TextBlock.SectionHeader">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Margin" Value="0,0,0,5"/>
      <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto, *">
    <!-- Modern Menu Bar -->
    <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,0,1">
      <Menu Height="32" VerticalAlignment="Center" Name="menuMain">
        <MenuItem Header="_File">
          <MenuItem Header="Open" HotKey="Ctrl+O" InputGesture="Ctrl+O" Name="menuOpen" Command="{Binding OpenFileCommand}" />
          <MenuItem Header="Load Package File" HotKey="Ctrl+P" InputGesture="Ctrl+P" Name="menuLoadPackageFile" Command="{Binding LoadPackageFileCommand}" />
          <MenuItem Header="Close" HotKey="Ctrl+W" InputGesture="Ctrl+W" Name="menuClose" Command="{Binding CloseCommand}" />
          <MenuItem Header="Save" HotKey="Ctrl+S" InputGesture="Ctrl+S" Name="menuSave" Command="{Binding SaveCommand}" />
          <MenuItem Header="Save as..." HotKey="Ctrl+Shift+S" InputGesture="Ctrl+Shift+S" Name="menuSaveAs" Command="{Binding SaveAsCommand}" />
          <Separator />
          <MenuItem Header="Compress" HotKey="Ctrl+M" InputGesture="Ctrl+M" Name="menuCompress" Command="{Binding CompressCommand}" />
          <MenuItem Header="Exit" HotKey="Ctrl+Q" InputGesture="Ctrl+Q" Name="menuExit" Command="{Binding ExitCommand}" />
        </MenuItem>
        <MenuItem Header="_Options">
          <MenuItem Header="Toggle Dark Theme" Name="menuToggleDarkTheme" Command="{Binding ToggleDarkThemeCommand}" />
          <MenuItem Header="Enable/Disable Cpp2Il" Name="menuToggleCpp2Il" Command="{Binding ToggleCpp2IlCommand}" />
        </MenuItem>
        <MenuItem Header="_Help">
          <MenuItem Header="About..." Name="menuAbout" Command="{Binding AboutCommand}" />
        </MenuItem>
      </Menu>
    </Border>

    <!-- Main Content Layout -->
    <Grid Grid.Row="1" Margin="10">

      <!-- Central Action Panel -->
      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" CornerRadius="8" Padding="15" BoxShadow="0 2 8 0 #10000000" MinWidth="400">
          <StackPanel Spacing="10" VerticalAlignment="Center">

            <TextBlock Classes="SectionHeader" Text="Workspace Overview" HorizontalAlignment="Center" />

            <Border Background="{DynamicResource SystemControlBackgroundChromeLowBrush}" CornerRadius="4" Padding="10">
              <TextBlock Text="{Binding FileName}" TextAlignment="Center" FontWeight="Normal" FontSize="12" Name="lblFileName" TextWrapping="Wrap" />
            </Border>

            <ComboBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}" HorizontalAlignment="Stretch" Height="30" IsEnabled="{Binding IsWorkspaceActive}" Name="comboBox" Margin="0,5,0,10">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="local:BundleWorkspaceItem">
                  <TextBlock Text="{Binding}" Foreground="{Binding Color}" VerticalAlignment="Center" FontSize="12" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Content="Asset Info" HorizontalAlignment="Stretch" IsEnabled="{Binding HasAssets}" Name="btnInfo" Command="{Binding OpenInfoCommand}" Height="35" Classes="accent" FontSize="14" FontWeight="SemiBold"/>

            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" Margin="0,5,0,0">
              <!-- Left Column: Export/Rename -->
              <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4" Margin="0,0,4,0">
                <Button Content="Export" HorizontalAlignment="Stretch" IsEnabled="{Binding HasAssets}" Name="btnExport" Command="{Binding ExportCommand}" FontSize="12" />
                <Button Content="Rename" HorizontalAlignment="Stretch" IsEnabled="{Binding HasAssets}" Name="btnRename" Command="{Binding RenameCommand}" FontSize="12" />
              </StackPanel>

              <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4" Margin="0,4,4,0">
                <Button Content="Export All" HorizontalAlignment="Stretch" IsEnabled="{Binding HasAssets}" Name="btnExportAll" Command="{Binding ExportAllCommand}" FontSize="12" />
              </StackPanel>

              <!-- Right Column: Import/Remove -->
              <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4" Margin="4,0,0,0">
                <Button Content="Import" HorizontalAlignment="Stretch" IsEnabled="{Binding IsWorkspaceActive}" Name="btnImport" Command="{Binding ImportCommand}" FontSize="12" />
                <Button Content="Remove" HorizontalAlignment="Stretch" IsEnabled="{Binding HasAssets}" Name="btnRemove" Command="{Binding RemoveCommand}" Foreground="#D32F2F" FontSize="12" />
              </StackPanel>

              <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4" Margin="4,4,0,0">
                <Button Content="Import All" HorizontalAlignment="Stretch" IsEnabled="{Binding IsWorkspaceActive}" Name="btnImportAll" Command="{Binding ImportAllCommand}" FontSize="12" />
              </StackPanel>
            </Grid>

          </StackPanel>
        </Border>
      </Viewbox>
    </Grid>
  </Grid>
</Window>
